# Cross-cutting (all workers)
LOG_LEVEL=INFO
TELEGRAM_REPORTING_ENABLED=true
TELEGRAM_PROGRESS_INTERVAL_MINUTES=30
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=

# PostgreSQL — pipeline state (all services)
POSTGRES_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/car_intel
# DATABASE_URL=  # legacy alias accepted by matching service and scripts

# MongoDB — raw ad storage (ingestion, archiving)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=etl
RAW_COLLECTION_NAME=raw_ads

# Parser API (ingestion)
PARSER_API_URL=https://highload.kocherov.net/parser/api/auto_api/
PARSER_API_KEY=replace-with-parser-api-key

# Elasticsearch — ingestion, matching, pipeline runner, and validation scripts
ELASTICSEARCH_URL=http://localhost:9200
PROCESSED_INDEX=carads1_local
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# Matching service worker
MATCHING_BATCH_SIZE=500
MATCHING_SITES=avito,drom,auto
MATCHING_MIN_SCORE=0.7
MATCHING_TIME_WINDOW_DAYS=5
MATCHING_PARSER_LAG_DAYS=3
MATCHING_PRICE_TOLERANCE=0.10
MATCHING_MILEAGE_TOLERANCE=0.05
MATCHING_MAX_RESULTS=200

# Archiving service (S3-compatible object storage)
ARCHIVE_RETENTION_DAYS=60
ARCHIVE_BATCH_SIZE=5000
S3_BUCKET=your-bucket
S3_PREFIX=raw-archive/
S3_ENDPOINT=https://storage.yandexcloud.net
AWS_ACCESS_KEY_ID=replace-with-access-key
AWS_SECRET_ACCESS_KEY=replace-with-secret-key
# AWS_REGION=

# Parser request format reference:
# https://highload.kocherov.net/parser/api/auto_api/?key=YOUR_KEY&site=auto&from_datetime=2019-01-01 00:00:00
