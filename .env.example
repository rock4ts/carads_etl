# Cross-cutting (all workers / scripts)
ETL_ENV=development
LOG_LEVEL=INFO
TELEGRAM_REPORTING_ENABLED=true
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHANNEL_ID=

# Ingestion / raw store (e.g. ingestion pipeline)
MONGODB_URI=mongodb://localhost:27017/etl
MONGO_URI=mongodb://localhost:27017
MONGO_DB=etl
RAW_COLLECTION_NAME=raw_ads
PARSER_API_URL=https://highload.kocherov.net/parser/api/auto_api/
PARSER_API_KEY=replace-with-parser-api-key

# Elasticsearch — shared by processing, matching, and validation scripts
ELASTICSEARCH_URL=http://localhost:9200
PROCESSED_INDEX=carads1_local
# ELASTICSEARCH_API_KEY=
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=

# Matching service worker (app.services.matching_service)
POSTGRES_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/car_intel
MATCHING_BATCH_SIZE=500
# MATCHING_SITES=site_a,site_b

# Parser request format reference:
# https://highload.kocherov.net/parser/api/auto_api/?key=YOUR_KEY&site=auto&from_datetime=2019-01-01 00:00:00
